---
import BaseLayout from "../components/layout/BaseLayout.astro";
import { EVENT_NAME } from "../data/eventConfig";
---

<BaseLayout title={`Detailed Analysis | ${EVENT_NAME}`}>
  <main class="min-h-screen py-8 px-4 md:py-16 md:px-8">
    <div class="w-full max-w-xl mx-auto space-y-6">
      <div class="text-center mb-8">
        <h1 class="text-2xl md:text-3xl font-heading font-bold text-white mb-2">Detailed Analysis</h1>
        <p class="text-brand-light/80 text-sm">Review your answers below.</p>
      </div>
      
      <div class="bg-brand-surface rounded-2xl p-6 md:p-12 shadow-xl border border-white/5 text-center text-brand-light/60">
        <p>DetailedAnalysis component will go here.</p>
      </div>
    </div>
  </main>
</BaseLayout>
