---
import BaseLayout from "../components/layout/BaseLayout.astro";
import {
	EVENT_NAME,
	EVENT_DATE,
	ORGANIZER_NAME,
	QUIZ_DURATION_SECONDS,
} from "../data/eventConfig";

const quizDurationMinutes = Math.floor(QUIZ_DURATION_SECONDS / 60);
---

<BaseLayout title={EVENT_NAME}>
	<!-- Intro Video Overlay -->
	<div
		id="intro-container"
		class="fixed inset-0 z-50 bg-black hidden items-center justify-center"
	>
		<video
			id="intro-video"
			class="w-full h-full object-cover md:object-contain"
			playsinline
			muted
		>
			<source src="/videos/intro_vid.webm" type="video/webm" />
		</video>
	</div>

	<div
		id="main-content"
		class="hidden opacity-0 transition-opacity duration-700 ease-in-out"
	>
		<main
			class="min-h-screen py-8 px-4 md:py-16 md:px-8 flex flex-col justify-center"
		>
			<div class="max-w-2xl mx-auto space-y-8 w-full">
				{/* Header Section */}
				<div class="text-center space-y-4">
					<div
						class="inline-block px-4 py-1.5 rounded-full bg-brand-surface border border-brand-primary/30 text-brand-primary text-sm font-medium mb-2"
					>
						{ORGANIZER_NAME} presents
					</div>
					<h1
						class="text-3xl md:text-5xl font-heading font-bold text-white leading-tight"
					>
						{EVENT_NAME}
					</h1>
					<p class="text-brand-light/80 text-base md:text-lg">
						Join us for an exciting, fast-paced quiz! Test your
						knowledge, compete with peers, and earn your
						participation certificate.
					</p>
					<p class="text-brand-primary font-medium">
						📅 {EVENT_DATE}
					</p>
				</div>

				{/* Rules Card */}
				<div
					class="bg-brand-surface rounded-2xl p-6 md:p-8 shadow-xl border border-white/5"
				>
					<h2
						class="text-2xl font-heading font-semibold text-white mb-6"
					>
						Quiz Rules
					</h2>

					<ul
						class="space-y-4 text-sm md:text-base text-brand-light/90"
					>
						<li class="flex items-start gap-3">
							<span
								class="text-brand-primary text-xl leading-none"
								>•</span
							>
							<span
								>Questions are shown <strong
									>one at a time</strong
								>. You cannot go back to previous questions.</span
							>
						</li>
						<li class="flex items-start gap-3">
							<span
								class="text-brand-primary text-xl leading-none"
								>•</span
							>
							<span
								>You may <strong>skip</strong> a question if you are
								unsure.</span
							>
						</li>
						<li class="flex items-start gap-3">
							<span
								class="text-brand-primary text-xl leading-none"
								>•</span
							>
							<span
								>Each correct answer is worth <strong
									>2 points</strong
								>. There is no negative marking for wrong or
								skipped answers.</span
							>
						</li>
					</ul>

					<div class="mt-8 space-y-4">
						<div
							class="bg-brand-warning/10 border border-brand-warning/20 rounded-xl p-4 flex gap-3"
						>
							<div class="text-brand-warning text-xl shrink-0">
								⏳
							</div>
							<div>
								<h3
									class="font-semibold text-brand-warning mb-1"
								>
									Timed Event
								</h3>
								<p class="text-sm text-brand-light/80">
									You have exactly <strong
										>{quizDurationMinutes} minutes</strong
									> to complete the quiz. It will auto-submit when
									time runs out.
								</p>
							</div>
						</div>

						<div
							class="bg-brand-danger/10 border border-brand-danger/20 rounded-xl p-4 flex gap-3"
						>
							<div class="text-brand-danger text-xl shrink-0">
								⚠️
							</div>
							<div>
								<h3
									class="font-semibold text-brand-danger mb-1"
								>
									Strict Anti-Cheat
								</h3>
								<p class="text-sm text-brand-light/80">
									Do not switch tabs, minimize your browser,
									or reload the page once started. Doing so
									may end your attempt immediately.
								</p>
							</div>
						</div>
					</div>
				</div>

				{/* Action Button */}
				<div class="pt-4">
					<a
						href="/register"
						class="block w-full text-center bg-brand-primary hover:bg-brand-primary/90 active:scale-95 transition-all duration-200 text-white font-semibold text-lg py-4 px-6 rounded-xl shadow-lg shadow-brand-primary/20"
					>
						Register & Start
					</a>
				</div>
			</div>
		</main>
	</div>

	<script is:inline>
		const introContainer = document.getElementById("intro-container");
		const mainContent = document.getElementById("main-content");
		const video = document.getElementById("intro-video");

		const hasPlayed = sessionStorage.getItem("intro_played");

		function showMainContent() {
			if (introContainer) {
				introContainer.style.display = "none";
			}
			if (mainContent) {
				mainContent.classList.remove("hidden");
				// Force reflow to ensure the transition works
				void mainContent.offsetWidth;
				mainContent.classList.remove("opacity-0");
				mainContent.classList.add("opacity-100");
			}
			// Stop video to save resources
			if (video) {
				video.pause();
				video.currentTime = 0;
			}
		}

		if (hasPlayed) {
			showMainContent();
		} else {
			if (introContainer) {
				introContainer.classList.remove("hidden");
				introContainer.style.display = "flex";
			}
			if (video) {
				// Attempt to play the video. Browsers might block autoplay even if muted.
				video.play().catch((err) => {
					console.warn("Video autoplay blocked or failed:", err);
					showMainContent(); // fallback
				});

				video.addEventListener("ended", () => {
					sessionStorage.setItem("intro_played", "true");
					showMainContent();
				});

				video.addEventListener("error", () => {
					sessionStorage.setItem("intro_played", "true");
					showMainContent();
				});
			}
		}
	</script>
</BaseLayout>
