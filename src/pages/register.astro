---
import BaseLayout from "../components/layout/BaseLayout.astro";
import { EVENT_NAME } from "../data/eventConfig";
import ParticipantForm from "../components/registration/ParticipantForm";
---

<BaseLayout title={`Register | ${EVENT_NAME}`}>
  <div class="min-h-screen bg-brand-surface-container flex flex-col">
    {/* Top Bar */}
    <header class="bg-white py-4 px-6 flex items-center justify-center gap-3 border-b border-brand-surface-container shadow-sm relative z-20">
      <img src="/images/title-logo.png" alt="Logo" class="h-8 w-auto object-contain" />
      <div class="font-heading font-black text-brand-primary text-xl tracking-wider uppercase">
        STUDENTS INDIA
      </div>
    </header>

    <main class="flex-1 flex flex-col items-center justify-center py-8 px-4">
      <ParticipantForm client:load />
    </main>
  </div>
</BaseLayout>
