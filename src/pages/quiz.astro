---
import BaseLayout from "../components/layout/BaseLayout.astro";
import { EVENT_NAME } from "../data/eventConfig";
---

<BaseLayout title={`Quiz | ${EVENT_NAME}`}>
  <main class="min-h-screen flex flex-col relative quiz-no-select">
    <div class="flex-1 w-full max-w-xl mx-auto p-4 flex items-center justify-center">
      <div class="text-center text-brand-light/60 p-8 border border-white/10 rounded-2xl">
        <p>QuizShell component will go here.</p>
      </div>
    </div>
  </main>
</BaseLayout>
